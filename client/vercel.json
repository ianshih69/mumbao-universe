{
  "devCommand": "npx vite --host 0.0.0.0 --configLoader runner",
  "buildCommand": "npx vite build --configLoader runner",
  "outputDirectory": "dist",
  "functions": {
    "api/ai-chat-message.js": {
      "includeFiles": "api/knowledge/guesthouse-rules.md"
    },
    "api/shop.js": {
      "includeFiles": "server/shopShared.js"
    },
    "api/admin-shop.js": {
      "includeFiles": "server/shopShared.js"
    },
    "api/social-upload.js": {
      "includeFiles": "server/shopShared.js"
    }
  },
  "rewrites": [
    {
      "source": "/((?!api(?:/|$)).*)",
      "destination": "/index.html"
    }
  ]
}
