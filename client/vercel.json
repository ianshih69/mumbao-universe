{
  "devCommand": "npx vite --host 0.0.0.0 --configLoader runner",
  "buildCommand": "npx vite build --configLoader runner",
  "outputDirectory": "dist",
  "functions": {
    "api/ai-chat-message.js": {
      "includeFiles": "api/knowledge/guesthouse-rules.md"
    },
    "api/shop-products.js": {
      "includeFiles": "api/_shop_shared.js"
    },
    "api/shop-product.js": {
      "includeFiles": "api/_shop_shared.js"
    },
    "api/shop-orders.js": {
      "includeFiles": "api/_shop_shared.js"
    }
  },
  "rewrites": [
    {
      "source": "/api/shop/products",
      "destination": "/api/shop-products"
    },
    {
      "source": "/api/shop/products/:slug",
      "destination": "/api/shop-product?slug=:slug"
    },
    {
      "source": "/api/shop/orders",
      "destination": "/api/shop-orders"
    },
    {
      "source": "/((?!api(?:/|$)).*)",
      "destination": "/index.html"
    }
  ]
}
